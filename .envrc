# direnv configuration for termhelp development.
#
# Activates when you `cd` into this repo (after `direnv allow`). Points the
# shell integration at the locally-built debug binary and the in-repo dev
# config, so sourcing shell/interpreter.{zsh,bash,fish} from another terminal
# session that has this repo's environment loaded will use the working copy.

# Local debug build of the interpreter binary.
export INTERPRETER_BIN="${PWD}/target/debug/interpreter"

# Put the debug build directory on PATH so plain `interpreter` also resolves
# to the local build when typed at a prompt.
PATH_add "${PWD}/target/debug"
